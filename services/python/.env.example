DATABASE_URL=postgresql+psycopg://diagrams:secret@your-rds-endpoint:5432/diagrams
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# gRPC server (legacy, for agent sidecars)
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
GRPC_MAX_WORKERS=10
GRPC_SERVICE_TOKEN=your-shared-token-here

# REST API (primary interface for Laravel)
REST_HOST=0.0.0.0
REST_PORT=8001

# RAG configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75

# Observability
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=
