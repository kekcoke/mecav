APP_NAME=Mecav
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mecav.example.com
LOG_CHANNEL=stderr
LOG_LEVEL=info
DB_CONNECTION=pgsql
DB_HOST=your-rds-endpoint
DB_PORT=5432
DB_DATABASE=diagrams
DB_USERNAME=diagrams
DB_PASSWORD=secret
GRPC_PYTHON_SERVICE_HOST=python-service:50051
GRPC_INSECURE=true
GRPC_SERVICE_TOKEN=your-shared-token-here
GRPC_TIMEOUT_MS=30000
SNAPSHOT_STORAGE_BYTES=10485760
SNAPSHOT_MAX_AGE_DAYS=90
EXPORT_QUOTA_BYTES=104857600
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379
